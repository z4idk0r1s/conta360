{
  "name": "conta360",
  "dockerComposeFile": ["../docker-compose.yml", "../docker-compose.override.yml"],
  "service": "devcontainer-service",
  "workspaceFolder": "/workspaces/conta360",
  "postCreateCommand": "bash ./.devcontainer/star2.sh",
  "forwardPorts": [3000, 3001, 3004, 5000, 5001, 5432, 8080],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      }
    }
  },
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:USERPROFILE}\\.nuget,target=/home/vscode/.nuget,type=bind"
  ]
}