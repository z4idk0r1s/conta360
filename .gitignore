# Ignore build outputs
bin/
obj/
*.dll
*.exe
*.pdb

# Ignore user-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore Rider, VSCode, and other IDE configs
.idea/
.vscode/
*.code-workspace

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore test results
TestResults/
*.trx
*.coverage

# Ignore log files and folders
logs/
*.log

# Ignore data and output files
*.xls
*.xlsx
*.csv
*.zip
*.txt

# Ignore npm/yarn/pnpm cache and output
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore published output
publish/
dist/
out/

# Ignore EF Core migrations snapshot files (optional)
MigrationsSnapshot.cs

# Ignore Docker artifacts
**/.dockerignore
docker-compose.override.yml

# Ignore environment files (secrets/config)
.env
.env.*

# Ignore coverage reports
coverage/
lcov-report/
*.lcov
*.nyc_output

# Ignore generated Swagger files (if any)
swagger/
swagger-ui/
openapi/

# Ignore backend/frontend IDE artifacts
*.dbmdl
*.jfm

# Ignore frontend build output
build/
.cache/
.eslintcache

# Ignore VS test artifacts
.vstest/

# Ignore custom cache or build folders
tmp/
temp/
.cache/
*.tmp

# Ignore Python virtual envs (if any scripts)
venv/
__pycache__/
*.pyc

# If using JetBrains Rider: ignore solution-wide caches
.idea/

# Optional: ignore database files for SQLite
*.db
*.db3

# Optional: ignore local backups
*.bak

# End of file