{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "Origins": [
      "http://localhost:3004",
      "http://localhost:3000",
      "http://localhost:4000"
    ]
  },
  "ExcelProcessor": {
    "MaxFileSizeBytes": 10485760,
    "AllowedFileTypes": [".xls", ".xlsx", ".csv"],
    "TimeoutSeconds": 30
  },
  "Validation": {
    "MaxInvoicesPerBatch": 1000,
    "ProcessingTimeoutSeconds": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=.;Initial Catalog=Conta360;Integrated Security=True;TrustServerCertificate=True"
  }
}