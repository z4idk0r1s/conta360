{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Information",
      "SubvencionesApp": "Debug"
    }
  },
  "DatabaseProvider": "POSTGRESQL",
  "ConnectionStrings": {
    "SQLiteConnection": "Data Source=subvenciones_dev.db;Cache=Shared",
    "POSTGRESQLConnection": ""
  },
  "ExternalServices": {
    "InfoSubvenciones": {
      "BaseUrl": "https://www.infosubvenciones.es/bdnstrans/",
      "TimeoutSeconds": 60,
      "MaxRetries": 1,
      "RetryDelaySeconds": 2
    }
  },
  "ApiSettings": {
    "EnableSwagger": true,
    "EnableCors": true,
    "EnableCompression": false,
    "DefaultPageSize": 10,
    "MaxPageSize": 100
  },
  "CacheSettings": {
    "DefaultExpirationMinutes": 5,
    "MasterDataExpirationHours": 1,
    "StatisticsExpirationMinutes": 5
  }
}
